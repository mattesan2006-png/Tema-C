#include <stdio.h>

int main()
{
    int opcion;

    int numeros[5] = {10,20,30,40,50};

    int n = 5;

    do
    {
        printf("\nMENU\n");
        printf("1) Mostrar\n");
        printf("2) Agregar\n");
        printf("3) Eliminar\n");
        printf("4) Salir\n");

        scanf("%d", &opcion);

        switch(opcion)
        {
            case 1:

                // Recorrer array

                for (int i = 0; i < n; i++)
                {
                    printf("%d\n", numeros[i]);
                }

                break;

            case 2:
            {
                // Agregar elemento

                int nuevo;

                printf("Nuevo numero: ");
                scanf("%d", &nuevo);

                numeros[n] = nuevo;

                n++;

                break;
            }

            case 3:
            {
                // Eliminar elemento

                int posicion;

                printf("Posicion a eliminar: ");
                scanf("%d", &posicion);

                for (int i = posicion; i < n - 1; i++)
                {
                    numeros[i] = numeros[i + 1];
                }

                n--;

                break;
            }

            case 4:

                printf("Saliendo...\n");

                break;

            default:

                printf("Opcion invalida\n");
        }

    } while(opcion != 4);

    return 0;
}
