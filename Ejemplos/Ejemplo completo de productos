#include <stdio.h>
#include <string.h>

#define MAX 100

// Struct
// Sirve para guardar datos de un producto

struct Producto
{
    int codigo;
    char nombre[20];
    float precio;
};

int main()
{
    // Array de structs

    struct Producto inventario[MAX] =
    {
        {5, "Mouse", 1500},
        {2, "Teclado", 3000},
        {8, "Monitor", 50000},
        {1, "Auriculares", 8000}
    };

    int n = 4;

    int i, j;

    struct Producto temp;

    // Bubble Sort
    // Ordena por codigo

    for (i = 0; i < n - 1; i++)
    {
        for (j = 0; j < n - 1 - i; j++)
        {
            if (inventario[j].codigo > inventario[j + 1].codigo)
            {
                temp = inventario[j];
                inventario[j] = inventario[j + 1];
                inventario[j + 1] = temp;
            }
        }
    }

    // Mostrar productos ordenados

    printf("PRODUCTOS ORDENADOS\n\n");

    for (i = 0; i < n; i++)
    {
        printf("%d %s %.2f\n",
               inventario[i].codigo,
               inventario[i].nombre,
               inventario[i].precio);
    }

    // Busqueda Binaria

    int buscado = 5;

    int inicio = 0;
    int fin = n - 1;

    while (inicio <= fin)
    {
        int medio = inicio + (fin - inicio) / 2;

        if (inventario[medio].codigo == buscado)
        {
            printf("\nProducto encontrado:\n");

            printf("%d %s %.2f\n",
                   inventario[medio].codigo,
                   inventario[medio].nombre,
                   inventario[medio].precio);

            break;
        }

        if (inventario[medio].codigo < buscado)
        {
            inicio = medio + 1;
        }
        else
        {
            fin = medio - 1;
        }
    }

    return 0;
}
