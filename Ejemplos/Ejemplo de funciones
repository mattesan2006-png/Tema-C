#include <stdio.h>

// Funcion con retorno
// Devuelve suma

int sumar(int a, int b)
{
    return a + b;
}

// Paso por referencia
// Modifica variable original

void aumentar(int *n)
{
    (*n)++;
}

int main()
{
    int x = 10;

    int resultado;

    resultado = sumar(5, 3);

    printf("Resultado: %d\n", resultado);

    aumentar(&x);

    printf("Nuevo valor: %d\n", x);

    return 0;
}
