//Mostrar:
//- número mayor
//- número menor
//de un array.

#include <stdio.h>

int main() {
    int array[5];
    int n = 5;
    int i;
    int mayor, menor;

    printf("Ingrese 5 números enteros:\n");

    for (i = 0; i < n; i++) {
        scanf("%d", &array[i]);
    }

    mayor = array[0];
    menor = array[0];

    for (i = 1; i < n; i++) {
        if (array[i] > mayor) {
            mayor = array[i];
        }
        if (array[i] < menor) {
            menor = array[i];
        }
    }

    printf("Número mayor: %d\n", mayor);
    printf("Número menor: %d\n", menor);

    return 0;
}
