//Pedir 5 números al usuario y mostrarlos.

#include <stdio.h>

int main() {
    int array[5];
    int n = 5;
    int i;

    printf("Ingrese 5 números enteros:\n");

    for (i = 0; i < n; i++) {
        scanf("%d", &array[i]);
    }

    for (i = 0; i < n; i++) {
        printf("%d\n", array[i]);
    }
}
