//Invertir un array.

#include <stdio.h>

int main() {
    int array[5] = {1, 2, 3, 4, 5};
    int n = 5;
    int i, j;

    for (i = 0, j = n - 1; i < j; i++, j--) {
        int temp = array[i];
        array[i] = array[j];
        array[j] = temp;
    }

    printf("Array invertido: ");
    for (i = 0; i < n; i++) {
        printf("%d ", array[i]);
    }
    printf("\n");

    return 0;
}
