//Contar cuántos números son pares.

#include <stdio.h>

int main() {
    int array[5];
    int n = 5;
    int i;
    int contadorPares = 0;

    printf("Ingrese 5 números enteros:\n");

    for (i = 0; i < n; i++) {
        scanf("%d", &array[i]);
        if (array[i] % 2 == 0) {
            contadorPares++;
        }
    }

    printf("Cantidad de números pares: %d\n", contadorPares);

    return 0;
}
