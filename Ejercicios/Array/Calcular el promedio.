//Calcular el promedio.

#include <stdio.h>

int main() {
    int array[5];
    int n = 5;
    int i;
    int suma = 0;
    float promedio;

    printf("Ingrese 5 números enteros:\n");

    for (i = 0; i < n; i++) {
        scanf("%d", &array[i]);
        suma += array[i];
    }

    promedio = (float)suma / n;

    printf("El promedio es: %.2f\n", promedio);

    return 0;
}
