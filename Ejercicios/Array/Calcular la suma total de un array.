//Calcular la suma total de un array.

#include <stdio.h>

int main() {
    int array[5];
    int n = 5;
    int i;
    int suma = 0;

    printf("Ingrese 5 números enteros:\n");

    for (i = 0; i < n; i++) {
        scanf("%d", &array[i]);
        suma += array[i];
    }

    printf("La suma total es: %d\n", suma);

    return 0;
}
